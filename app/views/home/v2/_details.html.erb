<%= turbo_frame_tag "details_#{device_id}" do %>
  <div class="details-panel">
    <%= render 'home/v2/details_status_content', device_id: device_id, status: status, msg: msg, info: info, state: state, user_maintenance: defined?(user_maintenance) ? user_maintenance : nil %>

    <div class="details-panel__actions-row">
      <%= button_to home_battery_history_path(car_id: device_id), method: :post, class: "btn", data: { turbo_stream: true } do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="18" height="12" rx="2"/><line x1="23" y1="13" x2="23" y2="11"/></svg>
        Bateria
      <% end %>
      <%= button_to home_historico_km_path(car_id: device_id), method: :post, class: "btn", data: { turbo_stream: true } do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        Histórico Km
      <% end %>
      <%= link_to home_location_path(car_id: device_id, url: info.url), class: "btn", data: { turbo_stream: true, turbo_prefetch: false } do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Ver no Maps
      <% end %>
    </div>

