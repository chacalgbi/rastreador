<%= render "page_header" do %>
  <%= render "page_header_breadcrumb", title: "Detalhes do Histórico" do %>
    <li class="breadcrumb-item"><%= link_to "Admin", admin_path %></li>
    <li class="breadcrumb-item"><%= link_to "Histórico", admin_historicos_path %></li>
  <% end %>

  <%= render "page_header_actions" do %>
    <%= link_to "Editar", edit_admin_historico_path(@historico), class: "btn btn-primary" %>
    <%= link_to "Deletar", [:admin, @historico], class: "btn btn-white", data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" } %>
  <% end %>
<% end %>

<div class="page-body">
  <div class="container-xl">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Histórico - <%= @historico.descricao %></h3>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-md-3">Device ID</dt>
          <dd class="col-md-9"><%= @historico.device_id %></dd>

          <dt class="col-md-3">Tipo</dt>
          <dd class="col-md-9"><span class="badge <%= @historico.tipo == 'semanal' ? 'bg-blue' : 'bg-green' %>"><%= @historico.tipo.capitalize %></span></dd>

          <dt class="col-md-3">Descrição</dt>
          <dd class="col-md-9"><%= @historico.descricao %></dd>

          <dt class="col-md-3">Número</dt>
          <dd class="col-md-9"><%= @historico.numero %></dd>

          <dt class="col-md-3">Ano</dt>
          <dd class="col-md-9"><%= @historico.ano %></dd>

          <dt class="col-md-3">Odômetro (período)</dt>
          <dd class="col-md-9"><%= @historico.odometro_formatado %></dd>

          <dt class="col-md-3">Horímetro (período)</dt>
          <dd class="col-md-9"><%= @historico.horimetro_formatado %></dd>

          <dt class="col-md-3">Odômetro início (cumulativo)</dt>
          <dd class="col-md-9"><%= @historico.odometro_inicio %> km</dd>

          <dt class="col-md-3">Horímetro início (cumulativo)</dt>
          <dd class="col-md-9"><%= @historico.horimetro_inicio %> min</dd>

          <dt class="col-md-3">Observação</dt>
          <dd class="col-md-9"><%= @historico.observacao.present? ? @historico.observacao : '—' %></dd>

          <dt class="col-md-3">Criado em</dt>
          <dd class="col-md-9"><%= @historico.created_at&.strftime("%d/%m/%Y %H:%M") %></dd>

          <dt class="col-md-3">Atualizado em</dt>
          <dd class="col-md-9"><%= @historico.updated_at&.strftime("%d/%m/%Y %H:%M") %></dd>
        </dl>
      </div>
    </div>
  </div>
</div>
