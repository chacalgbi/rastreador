      <%= link_to 'Motoristas', driver_index_path, class: "btn sidebar-menu__button" %>
      <%= link_to 'Config Alertas', details_path, class: "btn sidebar-menu__button" %>
      <%= link_to 'Notificações', notifications_path, class: "btn sidebar-menu__button" %>
      <%= link_to 'Relatório Checklists', check_lists_path, class: "btn sidebar-menu__button" %>
