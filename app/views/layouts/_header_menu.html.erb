<div class="flex items-center gap">
  <nav class="flex items-center gap text-sm text-subtle show@md" style="--column-gap: 1rem">
    <% if Current.user %>
      <%= link_to 'Veículos', root_path %>
      <% if Current.user.admin %>
        <%= link_to 'Motoristas', driver_index_path %>
        <%= link_to 'Config Alertas', details_path %>
        <%= link_to 'Notificações', notifications_path %>
        <%= link_to 'Relatório Checklists', check_lists_path %>
      <% elsif Current.user.pessoal %>
        <%= link_to 'Config Alertas', details_path %>
        <%= link_to 'Notificações', notifications_path %>
      <% end %>
    <% end %>
  </nav>
</div>

<div class="flex items-center gap" 
     data-controller="pwa-install"
     data-pwa-install-auto-prompt-value="false">
  <% if Current.user %>
    <button data-push-target="notificationButton" 
            data-action="click->push#initializePushNotifications"
            class="flex items-center gap text-primary text-sm"
            style="display: block;"
            title="Ativar notificações">
      <%= image_tag "message-circle-warning.svg", size: 30, aria: { hidden: true }, class: "invertible" %>
    </button>

    <button data-pwa-install-target="installButton"
            data-action="click->pwa-install#install"
            class="flex items-center gap text-primary text-sm"
            style="display: none;"
            title="Instalar aplicativo">
      <%= image_tag "download.svg", size: 30, aria: { hidden: true }, class: "invertible" %>
    </button>

    <%= form_with url: home_toggle_layout_path, method: :post, data: { turbo: false }, style: "margin: 0;" do %>
      <label style="display: flex; flex-direction: column; align-items: center; cursor: pointer; font-size: 0.65rem; gap: 0.15rem;">
        <span class="text-subtle">Mudar layout</span>
        <input type="checkbox"
               class="switch switch--green"
               onchange="this.form.requestSubmit()"
               <%= 'checked' if Current.user&.layout_version == 'v2' %>
        >
      </label>
    <% end %>

    <%= link_to edit_password_driver_path(Current.user), class: "text-primary", title: "Alterar senha" do %>
      <%= image_tag "key-square.svg", size: 24, aria: { hidden: true }, class: "invertible" %>
    <% end %>

    <%= link_to session_path(Current.session), data: { turbo_method: :delete }, class: "text-primary" do %>
      <%= image_tag "square-arrow-out-up-right.svg", size: 24, aria: { hidden: true }, class: "invertible" %>
      Sair
    <% end %>
  <% end %>
</div>