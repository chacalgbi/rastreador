<%= turbo_frame_tag "details_#{device_id}" do %>
  <div class="details-panel">
    <%= render 'home/v2/details_status_content', device_id: device_id, status: status, msg: msg, info: info, state: state, user_maintenance: defined?(user_maintenance) ? user_maintenance : nil %>

    <div class="details-panel__actions-row">
      <%= button_to home_battery_history_path(car_id: device_id), method: :post, class: "btn", data: { turbo_stream: true } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-battery-automotive"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M18 2a1 1 0 0 1 1 1v1a3 3 0 0 1 3 3v10a3 3 0 0 1 -3 3h-14a3 3 0 0 1 -3 -3v-10a3 3 0 0 1 3 -3v-1a1 1 0 1 1 2 0v1h10v-1a1 1 0 0 1 1 -1m-2 7.5a1 1 0 0 0 -1 1v.5h-.5a1 1 0 0 0 0 2h.5v.5a1 1 0 0 0 2 0v-.5h.5a1 1 0 0 0 0 -2h-.5v-.5a1 1 0 0 0 -1 -1m-6.5 1.5h-3a1 1 0 0 0 0 2h3a1 1 0 0 0 0 -2" /></svg>
        Bat
      <% end %>
      <%= button_to home_historico_km_path(car_id: device_id), method: :post, class: "btn", data: { turbo_stream: true } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-ruler-measure"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M19.875 12c.621 0 1.125 .512 1.125 1.143v5.714c0 .631 -.504 1.143 -1.125 1.143h-15.875a1 1 0 0 1 -1 -1v-5.857c0 -.631 .504 -1.143 1.125 -1.143h15.75" /><path d="M9 12v2" /><path d="M6 12v3" /><path d="M12 12v3" /><path d="M18 12v3" /><path d="M15 12v2" /><path d="M3 3v4" /><path d="M3 5h18" /><path d="M21 3v4" /></svg>
        KMs
      <% end %>
      <%= link_to home_location_path(car_id: device_id, url: info.url), class: "btn", data: { turbo_stream: true, turbo_prefetch: false } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-map-2"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 18.5l-3 -1.5l-6 3v-13l6 -3l6 3l6 -3v7.5" /><path d="M9 4v13" /><path d="M15 7v5.5" /><path d="M21.121 20.121a3 3 0 1 0 -4.242 0c.418 .419 1.125 1.045 2.121 1.879c1.051 -.89 1.759 -1.516 2.121 -1.879" /><path d="M19 18v.01" /></svg>
        Maps
      <% end %>
    </div>

    <% if false # TODO: descomentar quando for usar %>
    <% if @user_admin || @pessoal %>
      <div class="details-panel__actions-row">
        <div contents data-controller="dialog">
          <button type="button" class="btn" data-action="dialog#showModal">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            Zerar Odômetro
          </button>
          <dialog class="dialog" data-dialog-target="menu" role="alertdialog" aria-labelledby="dialog_label" aria-describedby="dialog_desc">
            <div class="dialog__content">
              <h2 class="text-lg font-semibold leading-none mbe-2" id="dialog_label">Tem certeza que deseja ZERAR o Odômetro?</h2>
              <p class="text-lg text-subtle mbe-4" id="dialog_desc">
                Esta ação não pode ser desfeita. Isso irá apagar permanentemente a contagem do Odômetro do seu veículo.
              </p>
              <div class="flex items-center justify-end gap">
                <button type="button" class="btn" data-action="click->dialog#close">Cancelar</button>
                <%= button_to "Confirmar",  home_odometro_path, method: :post, params: { device_id: info.device_id, model: info.model, command: "zerar_hodometro", imei: info.imei }, class: "btn btn-primary btn-sm", data: { turbo_stream: true, action: "click->dialog#close" }  %>
              </div>
            </div>
          </dialog>
        </div>

        <div contents data-controller="dialog">
          <button type="button" class="btn" data-action="dialog#showModal">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            Zerar Horímetro
          </button>
          <dialog class="dialog" data-dialog-target="menu" role="alertdialog" aria-labelledby="dialog_label" aria-describedby="dialog_desc">
            <div class="dialog__content">
              <h2 class="text-lg font-semibold leading-none mbe-2" id="dialog_label">Tem certeza que deseja ZERAR o Horímetro?</h2>
              <p class="text-lg text-subtle mbe-4" id="dialog_desc">
                Esta ação não pode ser desfeita. Isso irá apagar permanentemente a contagem do Horímetro do seu veículo.
              </p>
              <div class="flex items-center justify-end gap">
                <button type="button" class="btn" data-action="click->dialog#close">Cancelar</button>
                <%= button_to "Confirmar",  home_odometro_path, method: :post, params: { device_id: info.device_id, model: info.model, command: "zerar_horimetro", imei: info.imei }, class: "btn btn-primary btn-sm", data: { turbo_stream: true, action: "click->dialog#close" }  %>
              </div>
            </div>
          </dialog>
        </div>
      </div>
    <% end %>
    <% end %>

    <div id="detail_<%= device_id %>" > <!-- Será substituida quando o evento de Status for enviado pelo rastreador -->
      <%= render 'details/v2/information', info: info %>
    </div>

    <div style="margin-top: 0.75rem;">
      <% if events_count != 0 %>
        <%= button_to home_last_events_path(device_id: device_id, open: 'true'), method: :post, class: "btn btn--borderless", data: { turbo_stream: true } do %>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          <span>Eventos: <%= events_count %></span>
        <% end %>
      <% else %>
        <%= button_tag class: "btn btn--borderless", disabled: true do %>
          <span style="opacity: 0.5;">Sem eventos</span>
        <% end %>
      <% end %>
    </div>

    <div data-controller="map-toggle">
      <div class="map-toggle-row">
        <label>
          <input type="checkbox" class="switch switch--green" data-action="change->map-toggle#toggle" data-map-toggle-target="checkbox">
          <span>Mostrar no Mapa</span>
        </label>
      </div>

      <% coords = info.url.to_s.match(/q=(-?\d+\.?\d*),(-?\d+\.?\d*)/) %>
      <% lat = coords ? coords[1] : "-14.225129" %>
      <% lng = coords ? coords[2] : "-42.784456" %>

      <div id="map"
           class="map-container"
           style="display: none; border-radius: var(--rounded-lg); margin-top: 0.5rem;"
           data-controller="map"
           data-map-latitude-value="<%= lat %>"
           data-map-longitude-value="<%= lng %>"
           data-map-zoom-value="16"
           data-map-popup-value="<%= info.device_name %>"
           data-map-toggle-target="map">
      </div>
    </div>
  </div>
<% end %>
