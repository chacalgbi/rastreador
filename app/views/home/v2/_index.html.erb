<% if Current.user&.pessoal && Current.user&.active == false %>
  <div class="empty-state">
    <svg class="empty-state__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <h2>Acesso desativado</h2>
    <p>Você está com o acesso desativado. Entre em contato com o administrador.</p>
  </div>
<% else %>
  <div class="dashboard-header">
    <h1>Meus Veículos</h1>
    <% if @devices.present? %>
      <div class="dashboard-stats">
        <span class="stat-pill">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
          <%= @devices.total_count %> veículo(s)
        </span>
      </div>
    <% end %>
  </div>

  <%= turbo_stream_from "home_stream" %>

  <%= form_with(url: root_path, method: :get, data: {controller: "search-devices", turbo_frame: "devices_active"}, class: "search-bar-modern") do |form| %>
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <%= form.label :query, "Pesquisar Veículos", class: "text-sm font-medium leading-none" %>
    <%= form.text_field :query, data: {action: "input->search-devices#search"}, placeholder: "Pesquisar por modelo, código ou placa...", class: "input" %>
    <% if @search_query %>
      <%= link_to 'Limpar', home_index_path, class: "btn btn--secondary", style: "font-size: 0.8rem;" %>
    <% end %>
  <% end %>

  <% if @devices.present? %>
    <div class="pagination-wrapper">
      <%= paginate @devices %>
    </div>
    <div class="vehicles-grid">
      <% @devices.each.with_index(1) do |device, index| %>
        <%= render 'home/v2/car', car: device, index: index %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <svg class="empty-state__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
      <h2>Nenhum veículo disponível</h2>
      <p>Procure seu supervisor para liberar os veículos que você precisa acessar.</p>
    </div>
  <% end %>
<% end %>
