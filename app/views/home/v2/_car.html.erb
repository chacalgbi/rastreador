<div class="vehicle-card" data-status="<%= car.status %>" style="position: relative;">
  <div class="vehicle-card__header">
    <h2 class="vehicle-card__name">
      <span class="vehicle-icon">
        <%= vehicle_icon_svg(car.category) %>
      </span>
      <%= car.device_name %>
    </h2>
    <%= render 'home/v2/status_badge', detail: car %>
  </div>

  <div class="vehicle-card__meta">
    <span class="vehicle-card__speed">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M12 12l4 -3"/><path d="M16.5 7.5l.5 -.5"/></svg>
      V.Máx: <%= car.velo_max %>
    </span>
    <div>
      <%= turbo_frame_tag "details_button_#{car.device_id}" do %>
        <%= render 'details/v2/button_details', show_details: false, device_id: car.device_id, status: car.status %>
      <% end %>
    </div>
  </div>

  <div class="vehicle-card__details-area">
    <%= turbo_frame_tag "location_#{car.device_id}" do %><% end %>
    <%= turbo_frame_tag "details_#{car.device_id}" do %><% end %>
    <%= turbo_frame_tag "events_#{car.device_id}" do %><% end %>
  </div>

  <% if Current.user.admin? && Flipper.enabled?(:exibir_id_device_id_home) %>
    <div class="admin-debug-badge">
      id: <%= car.id %> device_id: <%= car.device_id %>
    </div>
  <% end %>
</div>
